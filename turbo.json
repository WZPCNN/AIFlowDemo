{
  "$schema": "https://turbo.build/schema.json",
  "task": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  }
}
